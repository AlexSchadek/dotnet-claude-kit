{
  "hooks": [
    {
      "event": "pre-commit",
      "command": "bash hooks/pre-commit-format.sh",
      "description": "Ensure code is formatted before commit"
    },
    {
      "event": "post-file-edit",
      "pattern": "*.csproj",
      "command": "bash hooks/post-scaffold-restore.sh",
      "description": "Auto-restore NuGet packages after project file changes"
    }
  ]
}
